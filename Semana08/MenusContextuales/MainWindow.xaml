<Window x:Class="MenusContextuales.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:MenusContextuales"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Button Content="Hacer Click Derecho" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Menu Item 1"/>
                    <MenuItem Header="Menu Item 2"/>
                    <Separator/>
                    <MenuItem Header="Menu Item 3"/>
                </ContextMenu>
            </Button.ContextMenu>
        </Button>
        <TextBox HorizontalAlignment="Center" Margin="0,278,0,0" TextWrapping="Wrap" Text="Click derecho aqui para desplegar Menu Contextual" Width="333" Height="18" VerticalAlignment="Top">
            <TextBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Cortar" Command="Cut">
                        <MenuItem.Icon>
                            <Image Source="/Iconos/icons8-cut-64.png"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Command="Copy">
                        <MenuItem.Icon>
                            <Image Source="/icons8-copy-30.png"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Command="Paste">
                        <MenuItem.Icon>
                            <materialDesign:PackIcon Kind="ContentPaste" Width="18">
                                
                            </materialDesign:PackIcon>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </TextBox.ContextMenu>
        </TextBox>

    </Grid>
</Window>
