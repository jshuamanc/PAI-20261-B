<Window x:Class="Temperaturas.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Temperaturas"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" Loaded="Window_Loaded">
    <Grid Margin="30">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <ListBox x:Name="lbxMesesMayores" Grid.Column="2" d:ItemsSource="{d:SampleData ItemCount=5}" Foreground="Black" Background="#FF9ADCA4"/>
        <StackPanel Grid.Column="1" Margin="10,0,10,0">
            <Button x:Name="btnCalcular" Content="Mostrar Calculos" Click="btnCalcular_Click"/>
            <TextBlock TextWrapping="Wrap" Text="Promedio" FontSize="15" Margin="0,15,0,0" TextAlignment="Center" Background="#FF9ADCA4"/>
            <TextBlock x:Name="tbPromedio" TextWrapping="Wrap" Text="0" FontSize="15" Margin="0,10,0,0" TextAlignment="Center" Background="#FF9ADCA4"/>
            <TextBlock TextWrapping="Wrap" Text="Nro. Temp. mayores Prom." FontSize="15" Margin="0,15,0,0" TextAlignment="Center" Background="#FF9ADCA4"/>
            <TextBlock x:Name="txtMayores" TextWrapping="Wrap" Text="0" FontSize="15" Margin="0,10,0,0" TextAlignment="Center" Background="#FF9ADCA4"/>
            <Button Content="Guardar Registros" Margin="0,20,0,0"/>
        </StackPanel>
        <Border BorderBrush="Black" BorderThickness="1" Background="#FFFBF7C8">
            <StackPanel>
                <TextBlock TextWrapping="Wrap" Text="Temperaturas Promedio Mensuales" FontWeight="Bold" FontSize="15" TextAlignment="Center" Margin="0,0,0,10"/>

                <UniformGrid Rows="6" Columns="2" Margin="15,0,15,0">
                    <StackPanel Orientation="Horizontal" Margin="5,3">
                        <TextBlock Text="Enero" Margin="0,0,10,0" Width="60" />
                        <TextBox x:Name="txtEnero" Width="60" HorizontalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="5,3">
                        <TextBlock Text="Julio" Margin="0,0,10,0" Width="60" />
                        <TextBox x:Name="txtJulio" Width="60" HorizontalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="5,3">
                        <TextBlock Text="Febrero" Margin="0,0,10,0" Width="60" />
                        <TextBox x:Name="txtFebrero" Width="60" HorizontalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="5,3">
                        <TextBlock Text="Agosto" Margin="0,0,10,0" Width="60" />
                        <TextBox x:Name="txtAgosto" Width="60" HorizontalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="5,3">
                        <TextBlock Text="Marzo" Margin="0,0,10,0" Width="60" />
                        <TextBox x:Name="txtMarzo" Width="60" HorizontalContentAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="5,3">
                        <TextBlock Text="Setiembre" Margin="0,0,10,0" Width="60" />
                        <TextBox x:Name="txtSetiembre" Width="60" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5,3">
                        <TextBlock Text="Abril" Margin="0,0,10,0" Width="60" />
                        <TextBox x:Name="txtAbril" Width="60" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5,3">
                        <TextBlock Text="Octubre" Margin="0,0,10,0" Width="60" />
                        <TextBox x:Name="txtOctubre" Width="60" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5,3">
                        <TextBlock Text="Mayo" Margin="0,0,10,0" Width="60" />
                        <TextBox x:Name="txtMayo" Width="60" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5,3">
                        <TextBlock Text="Noviembre" Margin="0,0,10,0" Width="60" />
                        <TextBox x:Name="txtNoviembre" Width="60" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5,3">
                        <TextBlock Text="Junio" Margin="0,0,10,0" Width="60" />
                        <TextBox x:Name="txtJunio" Width="60" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="5,3">
                        <TextBlock Text="Diciembre" Margin="0,0,10,0" Width="60" />
                        <TextBox x:Name="txtDiciembre" Width="60" HorizontalContentAlignment="Center"/>
                    </StackPanel>


                </UniformGrid>
                

            </StackPanel>
        </Border>

    </Grid>
</Window>
