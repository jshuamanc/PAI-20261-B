<Window x:Class="OrdenarCadena.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OrdenarCadena"
        mc:Ignorable="d"
        Title="OrdenarCadena" Height="450" Width="800">
    <Grid Margin="50,30,50,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel>
            <TextBox x:Name="txtListaNombres" TextWrapping="Wrap" Height="79" Text="Liliana Angelina Leticia Amanda Patricia Roxana Luana Laura Kiara Kimberly Synthia Cintia Cecilia Ana Lina Thalia Teresa Pierina" FontSize="15"/>
        </StackPanel>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="17*"/>
                <ColumnDefinition Width="53*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="btnDividir" Content="&lt;&lt;Listar&gt;&gt;" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="10,1,10,1" Margin="0,15,0,15"/>
        </Grid>
        <Grid Grid.Row="2" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="75"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="75"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ListBox x:Name="lbNombres" d:ItemsSource="{d:SampleData ItemCount=5}"/>
            <ListBox x:Name="lbNombresFiltrados" Grid.Column="4" d:ItemsSource="{d:SampleData ItemCount=5}"/>
            <StackPanel Grid.Column="2">
                <Label Content="Letra" FontWeight="Bold" HorizontalContentAlignment="Center"/>
                <TextBox x:Name="txtFiltrar" TextWrapping="Wrap" FontSize="15" HorizontalContentAlignment="Center" Margin="0,2,0,0"/>
                <Button x:Name="btnFiltrar" Content="&lt;&lt;Pasar&gt;&gt;" Margin="0,15,0,0"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="75"/>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="75"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="1" x:Name="txtTotalNombres" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Width="70" Margin="5,5,0,0"/>
            <TextBox Grid.Column="3" x:Name="txtTotalFiltrados" HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Width="70" Margin="0,5,5,0"/>
            

        </Grid>

    </Grid>
</Window>
