<Window x:Class="RegistroClientes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RegistroClientes"
        mc:Ignorable="d"
        Title="MainWindow" Height="550" Width="800">
    <Grid Margin="20,24,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <Label Content="Apellidos" FontWeight="Bold"/>
                <TextBox x:Name="txtApellidos" TextWrapping="Wrap" FontSize="15" Height="25"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <Label Content="Nombres" FontWeight="Bold"/>
                <TextBox x:Name="txtNombres" TextWrapping="Wrap" FontSize="15" Height="25"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <Label Content="D.N.I" FontWeight="Bold"/>
                <TextBox x:Name="txtDNI" TextWrapping="Wrap" Height="25" FontSize="15"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <Label Content="Dirección" FontWeight="Bold"/>
                <TextBox x:Name="txtDireccion" TextWrapping="Wrap" Height="25" FontSize="15"/>
            </StackPanel>

        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <Label Content="Estado Civil"/>
                <ComboBox x:Name="cbxEstadoCivil" Height="25">
                    <ComboBoxItem Content="Soltero(a)"/>
                    <ComboBoxItem Content="Casado(a)"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10,10,10,10">
                <Button x:Name="btnGrabar" Content="Grabar" Click="btnGrabar_Click" Width="70" Margin="2,0,0,0"/>
                <Button x:Name="btnNuevo" Content="Nuevo" Width="70" Margin="2,0,0,0" Click="btnNuevo_Click"/>
                <Button x:Name="btnEstadistica" Content="Estadistica" Width="70" Margin="2,0,0,0" Click="btnEstadistica_Click" />
                <Button x:Name="btnSalir" Content="Salir" Width="70" Margin="2,0,0,0" Click="btnSalir_Click"/>
            </StackPanel>
        </Grid>




        <ListView x:Name="lvClientes" Margin="0,10,0,0" Grid.Row="3">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Apellidos" Width="150" DisplayMemberBinding="{Binding Apellidos}"/>
                    <GridViewColumn Header="Nombres" Width="150" DisplayMemberBinding="{Binding Nombres}"/>
                    <GridViewColumn Header="DNI" Width="80" DisplayMemberBinding="{Binding Dni}"/>
                    <GridViewColumn Header="Dirección" Width="200" DisplayMemberBinding="{Binding Direccion}"/>
                    <GridViewColumn Header="Estado Civil" Width="80" DisplayMemberBinding="{Binding EstadoCivil}"/>
                </GridView>
            </ListView.View>
        </ListView>



        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="10,10,10,10" HorizontalAlignment="Center">
            <Label Content="Solteros"/>
            <TextBox x:Name="txtSolteros" TextWrapping="Wrap" Width="120"/>
            <Label Content="Casados" Margin="50,0,0,0"/>
            <TextBox x:Name="txtCasados" TextWrapping="Wrap" Width="120"/>
        </StackPanel>
    </Grid>
</Window>
