<Window x:Class="Semana04.ComboBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Semana04"
        mc:Ignorable="d"
        Title="ComboBox" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Row="0" Grid.Column="0">
            <ComboBox x:Name="cmbFrutas" HorizontalAlignment="Left" Width="261">
                <ComboBoxItem Content="Fresa"/>
                <ComboBoxItem Content="Piña"/>
                <ComboBoxItem Content="Naranja"/>
                <ComboBoxItem Content="Mandarina"/>
            </ComboBox>
            <Button x:Name="btnMostrar" Content="Mostrar" Width="260" HorizontalAlignment="Left" Margin="0,20,0,0" Click="btnMostrar_Click"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,171">
            <Label Content="Fruta:"/>
            <TextBox x:Name="txtFruta" TextWrapping="Wrap" Width="235" Margin="20,0,0,0"/>
            <Button x:Name="btnAgregar" Content="Agregar" Width="78" Click="btnAgregar_Click"/>
        </StackPanel>

    </Grid>
</Window>
